@namespace(uri="library", prefix="")
package library;

class Library {
   val Writer[*] writers;
   val Book[*] books;
}

class Writer {
   id attr String ID;
   attr String name;
   ref Book[*] books;
}

class Book {
   id attr String ID;
   attr String title;
   attr int pages = 100;
   attr BookCategory category;
}

enum BookCategory {
   History;
   Geography;
}